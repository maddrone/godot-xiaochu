; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text if you know what you're doing.

config_version=4

_global_script_classes=[  ]
_global_script_class_icons={  }

[application]

config/name="Match3 - 开心消消乐"
config/description="A juicy match-3 puzzle game built with Godot 3.5 LTS"
run/main_scene="res://scenes/Main.tscn"
config/icon="res://icon.png"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
LevelManager="*res://scripts/autoload/LevelManager.gd"

[display]

window/size/width=720
window/size/height=1280
window/size/test_width=360
window/size/test_height=640
window/stretch/mode="2d"
window/stretch/aspect="keep_height"
window/handheld/orientation="portrait"

[input]

touch={
"deadzone": 0.5,
"events": [ Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"button_mask":0,"position":Vector2( 0, 0 ),"global_position":Vector2( 0, 0 ),"factor":1.0,"button_index":1,"pressed":false,"doubleclick":false,"script":null)
 ]
}

[rendering]

quality/driver/driver_name="GLES2"
quality/intended_usage/framebuffer_allocation=0
quality/intended_usage/framebuffer_allocation.mobile=0
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_clear_color=Color( 0.12, 0.11, 0.18, 1 )
quality/filters/msaa=0
quality/filters/use_fxaa=false
